{
  "info": {
    "_postman_id": "spotsync-2026-collection-0001",
    "name": "SpotSync API",
    "description": "Complete collection for the SpotSync – Smart Parking & EV Charging Reservation API.\n\nHOW TO USE:\n1. Make sure your server is running (go run main.go) on http://localhost:8080\n2. Run requests from top to bottom.\n3. 'Login (Admin)' and 'Login (Driver)' automatically save the JWT into collection variables (admin_token / driver_token). You do NOT need to copy tokens by hand.\n4. Admin-only requests use {{admin_token}}; driver requests use {{driver_token}}.\n\nVARIABLES:\n- base_url: defaults to http://localhost:8080\n- admin_token / driver_token: filled in automatically after login\n- zone_id / reservation_id: captured automatically after create requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "driver_token", "value": "", "type": "string" },
    { "key": "zone_id", "value": "", "type": "string" },
    { "key": "reservation_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] }
      },
      "response": []
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('success is true', function () { pm.expect(json.success).to.eql(true); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@spotsync.com\",\n  \"password\": \"securePassword123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Register (Driver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Driver\",\n  \"email\": \"john@spotsync.com\",\n  \"password\": \"pass123456\",\n  \"role\": \"driver\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login (Admin)  -> saves admin_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('admin_token', json.data.token);",
                  "  console.log('admin_token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@spotsync.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Login (Driver)  -> saves driver_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('driver_token', json.data.token);",
                  "  console.log('driver_token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@spotsync.com\",\n  \"password\": \"pass123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Parking Zones",
      "item": [
        {
          "name": "Create Zone (Admin)  -> saves zone_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('zone_id', json.data.id);",
                  "  console.log('zone_id saved: ' + json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Terminal 1 EV Charging\",\n  \"type\": \"ev_charging\",\n  \"total_capacity\": 20,\n  \"price_per_hour\": 5.50\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zones",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zones"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Zones (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/zones",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zones"]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Zone (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/zones/{{zone_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zones", "{{zone_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Zone (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price_per_hour\": 6.75,\n  \"total_capacity\": 25\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zones/{{zone_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zones", "{{zone_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Zone as Driver (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 403 Forbidden', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driver_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hacker Zone\",\n  \"type\": \"general\",\n  \"total_capacity\": 5,\n  \"price_per_hour\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zones",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zones"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Reserve Spot (Driver)  -> saves reservation_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('reservation_id', json.data.id);",
                  "  console.log('reservation_id saved: ' + json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driver_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zone_id\": {{zone_id}},\n  \"license_plate\": \"ABC-1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/reservations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations"]
            }
          },
          "response": []
        },
        {
          "name": "Reserve without token (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401 Unauthorized', function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zone_id\": {{zone_id}},\n  \"license_plate\": \"XYZ-9999\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/reservations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations"]
            }
          },
          "response": []
        },
        {
          "name": "Get My Reservations (Driver)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driver_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/reservations/my-reservations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations", "my-reservations"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Reservations (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/reservations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Reservation (Driver)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driver_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/reservations/{{reservation_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations", "{{reservation_id}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
